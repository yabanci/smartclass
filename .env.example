# Copy to .env and edit. All values are optional — the compose file has sane defaults.

# Postgres
POSTGRES_USER=smartclass
POSTGRES_PASSWORD=smartclass
POSTGRES_DB=smartclass
POSTGRES_PORT=5432

# Backend
APP_ENV=development
HTTP_PORT=8080
JWT_SECRET=change-me-in-production-at-least-32-bytes-long

# Frontend
FRONTEND_PORT=3000

# Home Assistant
HA_PORT=8123
TZ=Asia/Almaty

# MQTT (Mosquitto)
MQTT_PORT=1883
MQTT_WS_PORT=9001
