APP_ENV=development
HTTP_ADDR=:8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=smartclass
DB_PASSWORD=smartclass
DB_NAME=smartclass
DB_SSLMODE=disable

JWT_SECRET=change-me-in-production-at-least-32-bytes-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

BCRYPT_COST=10
RATE_LIMIT_RPS=50

CORS_ORIGINS=*

MIGRATIONS_DIR=./migrations
I18N_DIR=./locales
